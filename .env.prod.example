# === Production .env for cPanel (api.smcacademy.org) ===
# Put this file at the app root: /home/smca/api.smcacademy.org/.env
# DJANGO_ENV is also forced to "prod" by passenger_wsgi.py, but keep it here too.
DJANGO_ENV=prod

# Reuse your existing strong key (must NOT contain "dev-only-insecure").
DJANGO_SECRET_KEY=CHANGE-ME-strong-random-key

# The API subdomain only. No localhost in prod.
DJANGO_ALLOWED_HOSTS=api.smcacademy.org

# PostgreSQL created in cPanel (Databases > PostgreSQL Databases).
DATABASE_URL=postgres://stmark_app:PASSWORD@127.0.0.1:5432/stmark

# Outgoing mail (cPanel mailbox).
EMAIL_HOST=mail.smcacademy.org
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=info@smcacademy.org
EMAIL_HOST_PASSWORD=your-mailbox-password
DEFAULT_FROM_EMAIL="St. Mark Coptic Academy" <info@smcacademy.org>

# Frontend origins allowed to call the API (Next.js site).
CORS_ALLOWED_ORIGINS=https://smcacademy.org,https://www.smcacademy.org
CSRF_TRUSTED_ORIGINS=https://smcacademy.org,https://www.smcacademy.org
FRONTEND_LOGIN_URL=https://smcacademy.org/login

# Randomize the Django admin path (checklist 5.9). Keep the trailing slash.
DJANGO_ADMIN_PATH=smca-control-9f3b/
