# Copy to .env and fill in. All values optional in dev (SQLite + console email).
DJANGO_ENV=dev
DJANGO_SECRET_KEY=change-me-in-prod
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1

# PostgreSQL (spec target). Leave unset in dev to use local SQLite.
# DATABASE_URL=postgres://postgres:postgres@127.0.0.1:5432/stmark

# Academy mail server (outgoing: 587 STARTTLS)
EMAIL_HOST=mail.smcacademy.org
EMAIL_PORT=587
EMAIL_HOST_USER=info@smcacademy.org
EMAIL_HOST_PASSWORD=put-the-mailbox-password-here
DEFAULT_FROM_EMAIL="St. Mark Coptic Academy" <info@smcacademy.org>

CORS_ALLOWED_ORIGINS=http://localhost:3000
